{
  "name": "petcircle",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:web": "pnpm --filter @petcircle/web dev",
    "build:web": "pnpm --filter @petcircle/web build",
    "test:web": "pnpm --filter @petcircle/web test",
    "dev:api": "pnpm --filter @petcircle/api dev",
    "build:api": "pnpm --filter @petcircle/api build",
    "test:api": "pnpm --filter @petcircle/api test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "typescript-eslint": "^8.37.0"
  }
}
